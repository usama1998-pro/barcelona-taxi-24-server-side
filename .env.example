APP_NAME=Taxi Booking API
APP_ENV=development
# Public URL of this API (used by links in emails and HTTP-based scripts).
# Production example: https://taxibarcelonas.com
APP_URL=http://localhost:8000
# Staff admin UI (bookings + logs) is served at {APP_URL}/my-portal
# Optional override for scripts that call the REST API (--http mode):
# API_BASE_URL=https://taxibarcelonas.com/api/v1
HOST=0.0.0.0
PORT=8000

# IANA timezone for pickup calendar days and booking list tabs (Current/Past/Upcoming).
# Falls back to TZ when unset. Production (Barcelona): Europe/Madrid
BOOKING_TZ=Europe/Madrid

# IANA timezone (logs, datetime). Barcelona uses Spain civil time.
TZ=Europe/Madrid

# Logging (rotating file + optional console)
LOG_FILE=logs/app.log
LOG_CONSOLE=true
LOG_FILE_MAX_FILES=3
LOG_FILE_MAX_SIZE=20mb
# LOG_FILE_ENABLED=true
# LOG_LEVEL=info

# Host vs Docker: compose maps host port DATABASE_PORT -> container 3306 (see docker-compose.yml).
# - API on your machine: DATABASE_HOST=127.0.0.1, DATABASE_PORT=<published host port>
# - API in Docker on taxi-booking network: DATABASE_HOST=mysql, DATABASE_PORT=3306
#
# Root password is only for the DB container / admin tools (MYSQL_ROOT_PASSWORD / DATABASE_ROOT_PASSWORD).

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=taxi
DATABASE_PASSWORD=taxi
DATABASE_NAME=taxi_booking
# DATABASE_ROOT_PASSWORD=taxi_root

# Shared hosting (e.g. Hostinger):
# DATABASE_POOL_CONNECTION_LIMIT=1
# DATABASE_SSL=1
# DATABASE_CONNECT_TIMEOUT_MS=30000
# DATABASE_SSL_REJECT_UNAUTHORIZED=0
# DATABASE_ALLOW_PUBLIC_KEY_RETRIEVAL=1

# Run Alembic migrations on startup (local/production deploy):
# ALEMBIC_MIGRATE_ON_START=1
#
# If the database was already migrated by backend Prisma, stamp Alembic once instead of upgrading:
#   alembic stamp head
